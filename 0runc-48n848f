import psutil

WATCHLIST = [
    "keylogger",
    "sniffer",
    "remote_access"
]

def detect_intrusions():

    alerts = []

    for proc in psutil.process_iter(['name']):

        try:

            name = proc.info['name']

            if name:

                lower = name.lower()

                for item in WATCHLIST:

                    if item in lower:

                        alerts.append(name)

        except:
            pass

    return alerts

