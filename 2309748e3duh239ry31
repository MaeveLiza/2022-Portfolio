from cryptography.fernet import Fernet
import hashlib
import base64

class EncryptionCore:

    def __init__(self, secret):

        digest = hashlib.sha3_512(secret.encode()).digest()

        key = base64.urlsafe_b64encode(digest[:32])

        self.cipher = Fernet(key)

    def encrypt(self, text):

        return self.cipher.encrypt(text.encode())

    def decrypt(self, token):

        return self.cipher.decrypt(token).decode()

import psutil

WATCHLIST = [
    "keylogger",
    "sniffer",
    "remote_access"
]

def detect_threats():

    alerts = []

    for proc in psutil.process_iter(['name']):

        try:
            name = proc.info['name']

            if name:

                lower = name.lower()

                for item in WATCHLIST:

                    if item in lower:

                        alerts.append(name)

        except:
            pass

    return alerts

def emergency_lockdown():

